{
  "name": "jonykru.com",
  "version": "2.22.1",
  "private": true,
  "scripts": {
    "predev": "tsx scripts/generate-version.ts",
    "dev": "next dev",
    "prebuild": "tsx scripts/generate-version.ts",
    "build": "NODE_ENV=production next build",
    "build-analyze": "ANALYZE=true NODE_ENV=development next build",
    "version:patch": "pnpm version patch --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "version:major": "pnpm version major --no-git-tag-version",
    "start": "npx serve out",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx}\"",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky",
    "update-credly": "tsx scripts/update-credly.ts",
    "update-medium": "tsx scripts/update-medium.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@formspree/react": "^3.0.0",
    "@headlessui/react": "^2.2.10",
    "@mantine/hooks": "^9.3.2",
    "autoprefixer": "^10.5.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-intersection-observer": "^10.0.3",
    "react-type-animation": "^3.2.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "tsc-files": "^1.1.4",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.config).{ts,tsx}": [
      "tsc-files --skipLibCheck --noEmit --project tsconfig.json"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.3",
      "react-dom": "^19.2.3"
    }
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.26.1",
  "volta": {
    "node": "24.5.0"
  }
}
