{
  "name": "jonykru.com",
  "version": "3.8.1",
  "private": true,
  "scripts": {
    "predev": "tsx scripts/generate-version.ts && tsx scripts/generate-og.tsx",
    "dev": "next dev",
    "prebuild": "tsx scripts/generate-version.ts && tsx scripts/generate-og.tsx",
    "build": "NODE_ENV=production next build",
    "build-analyze": "ANALYZE=true NODE_ENV=development next build",
    "version:patch": "pnpm version patch --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "version:major": "pnpm version major --no-git-tag-version",
    "start": "npx serve out",
    "lint": "eslint . && pnpm check-flat",
    "lint:fix": "eslint . --fix",
    "check-flat": "tsx scripts/check-flat.ts",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx}\"",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky",
    "update-credly": "tsx scripts/update-credly.ts",
    "update-medium": "tsx scripts/update-medium.ts",
    "update-oss": "tsx scripts/update-oss.ts",
    "import-medium": "tsx scripts/import-medium-export.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-og": "tsx scripts/generate-og.tsx"
  },
  "dependencies": {
    "@formspree/react": "^3.0.0",
    "@headlessui/react": "^2.2.10",
    "autoprefixer": "^10.5.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/eslintrc": "^3.3.6",
    "@next/bundle-analyzer": "^16.2.10",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tsc-files": "^1.1.4",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.config).{ts,tsx}": [
      "tsc-files --skipLibCheck --noEmit --project tsconfig.json"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.3",
      "react-dom": "^19.2.3"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-import>eslint": "10",
        "eslint-plugin-jsx-a11y>eslint": "10",
        "eslint-plugin-react>eslint": "10"
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.26.1",
  "volta": {
    "node": "24.5.0"
  }
}
